<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- Stage 0: Options presented immediately -->
	<FactionColonies.FCEventDef>
		<defName>empireEvents_marketBoom_0</defName>
		<label>Market Boom</label>
		<desc>Demand for your goods has surged across the region. Merchants are clamoring for everything your settlements can produce. How should your empire respond to this opportunity?</desc>
		<category>EC_Economy</category>
		<timeTillTrigger>0</timeTillTrigger>
		<options>
			<li>empireEvents_marketBoom_opt1</li>
			<li>empireEvents_marketBoom_opt2</li>
			<li>empireEvents_marketBoom_opt3</li>
		</options>
		<activateAtStart>true</activateAtStart>
		<isRandomEvent>true</isRandomEvent>
		<weight>20</weight>
		<rangeSettlementsAffected>2~4</rangeSettlementsAffected>
		<settlementsCarryOver>true</settlementsCarryOver>
		<incompatibleEvents>
			<li>empireEvents_marketBoom_1a</li>
			<li>empireEvents_marketBoom_1b</li>
			<li>empireEvents_marketBoom_1c</li>
		</incompatibleEvents>
	</FactionColonies.FCEventDef>

	<!-- Option A: Capitalize aggressively -->
	<FactionColonies.FCOptionDef>
		<defName>empireEvents_marketBoom_opt1</defName>
		<label>Capitalize aggressively — push workers to meet demand at any cost.</label>
		<parentEvent>empireEvents_marketBoom_0</parentEvent>
		<baseChanceOfSuccess>100</baseChanceOfSuccess>
		<silverCost>0</silverCost>
		<successEvent>empireEvents_marketBoom_1a</successEvent>
	</FactionColonies.FCOptionDef>

	<!-- Option B: Steady growth -->
	<FactionColonies.FCOptionDef>
		<defName>empireEvents_marketBoom_opt2</defName>
		<label>Maintain a steady pace — take what profit we can without overextending.</label>
		<parentEvent>empireEvents_marketBoom_0</parentEvent>
		<baseChanceOfSuccess>100</baseChanceOfSuccess>
		<silverCost>0</silverCost>
		<successEvent>empireEvents_marketBoom_1b</successEvent>
	</FactionColonies.FCOptionDef>

	<!-- Option C: Invest in infrastructure -->
	<FactionColonies.FCOptionDef>
		<defName>empireEvents_marketBoom_opt3</defName>
		<label>Invest the windfall into long-term infrastructure improvements.</label>
		<parentEvent>empireEvents_marketBoom_0</parentEvent>
		<baseChanceOfSuccess>100</baseChanceOfSuccess>
		<silverCost>0</silverCost>
		<successEvent>empireEvents_marketBoom_1c</successEvent>
	</FactionColonies.FCOptionDef>

	<!-- Outcome A: High reward, production penalties -->
	<FactionColonies.FCEventDef>
		<defName>empireEvents_marketBoom_1a</defName>
		<label>Market Boom (Aggressive)</label>
		<desc>Your settlements are working overtime to meet surging demand. Silver flows in, but the relentless pace is wearing on food supplies and forestry operations.</desc>
		<category>EC_Economy</category>
		<timeTillTrigger>300000</timeTillTrigger>
		<statModifiers>
			<li><stat>titheValueMultiplier</stat><value>0.2</value></li>
			<li><stat>RTD_Food_ProductionAdditive</stat><value>-0.5</value></li>
			<li><stat>RTD_Logging_ProductionAdditive</stat><value>-0.5</value></li>
		</statModifiers>
		<rangeSettlementsAffected>2~4</rangeSettlementsAffected>
		<settlementsCarryOver>true</settlementsCarryOver>
		<incompatibleEvents>
			<li>empireEvents_marketBoom_0</li>
		</incompatibleEvents>
	</FactionColonies.FCEventDef>

	<!-- Outcome B: Moderate reward, no penalties -->
	<FactionColonies.FCEventDef>
		<defName>empireEvents_marketBoom_1b</defName>
		<label>Market Boom (Steady)</label>
		<desc>Your settlements capitalize on the market boom at a sustainable pace. A modest but reliable increase in trade revenue.</desc>
		<category>EC_Economy</category>
		<timeTillTrigger>300000</timeTillTrigger>
		<statModifiers>
			<li><stat>titheValueMultiplier</stat><value>0.1</value></li>
		</statModifiers>
		<rangeSettlementsAffected>2~4</rangeSettlementsAffected>
		<settlementsCarryOver>true</settlementsCarryOver>
		<incompatibleEvents>
			<li>empireEvents_marketBoom_0</li>
		</incompatibleEvents>
	</FactionColonies.FCEventDef>

	<!-- Outcome C: No immediate bonus, long-term multiplier boost -->
	<FactionColonies.FCEventDef>
		<defName>empireEvents_marketBoom_1c</defName>
		<label>Market Boom (Investment)</label>
		<desc>Rather than chasing short-term profits, your settlements reinvest the boom's momentum into lasting infrastructure. Production efficiency improves across the board.</desc>
		<category>EC_Economy</category>
		<timeTillTrigger>600000</timeTillTrigger>
		<statModifiers>
			<li><stat>RTD_Food_ProductionMultiplier</stat><value>0.1</value></li>
			<li><stat>RTD_Weapons_ProductionMultiplier</stat><value>0.1</value></li>
			<li><stat>RTD_Apparel_ProductionMultiplier</stat><value>0.1</value></li>
			<li><stat>RTD_Animals_ProductionMultiplier</stat><value>0.1</value></li>
			<li><stat>RTD_Logging_ProductionMultiplier</stat><value>0.1</value></li>
			<li><stat>RTD_Mining_ProductionMultiplier</stat><value>0.1</value></li>
			<li><stat>RTD_Research_ProductionMultiplier</stat><value>0.1</value></li>
			<li><stat>RTD_Power_ProductionMultiplier</stat><value>0.1</value></li>
			<li><stat>RTD_Medicine_ProductionMultiplier</stat><value>0.1</value></li>
			<li><stat>RTD_Chemfuel_ProductionMultiplier</stat><value>0.1</value></li>
		</statModifiers>
		<rangeSettlementsAffected>2~4</rangeSettlementsAffected>
		<settlementsCarryOver>true</settlementsCarryOver>
		<incompatibleEvents>
			<li>empireEvents_marketBoom_0</li>
		</incompatibleEvents>
	</FactionColonies.FCEventDef>

</Defs>
