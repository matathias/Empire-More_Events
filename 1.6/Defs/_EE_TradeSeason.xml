<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- Stage 0: Trade season arrives -->
	<FactionColonies.FCEventDef>
		<defName>empireEvents_tradeSeason_0</defName>
		<label>Trade Season</label>
		<desc>Favorable weather, safe roads, and high demand have converged into the most promising trade season in years. Merchants flock to your settlements from across the region, eager to buy and sell. How do you capitalize on this windfall?</desc>
		<category>EC_Economy</category>
		<timeTillTrigger>0</timeTillTrigger>
		<options>
			<li>empireEvents_tradeSeason_opt1</li>
			<li>empireEvents_tradeSeason_opt2</li>
			<li>empireEvents_tradeSeason_opt3</li>
		</options>
		<activateAtStart>true</activateAtStart>
		<isRandomEvent>true</isRandomEvent>
		<weight>15</weight>
		<cooldownTicks>1800000</cooldownTicks>
		<minSettlements>2</minSettlements>
		<minDaysSinceFounded>30</minDaysSinceFounded>
		<targetAllSettlements>true</targetAllSettlements>
		<settlementsCarryOver>true</settlementsCarryOver>
		<incompatibleEvents>
			<li>empireEvents_tradeSeason_open</li>
			<li>empireEvents_tradeSeason_aggressive</li>
			<li>empireEvents_tradeSeason_invest</li>
		</incompatibleEvents>
	</FactionColonies.FCEventDef>

	<!-- Option A: Open markets -->
	<FactionColonies.FCOptionDef>
		<defName>empireEvents_tradeSeason_opt1</defName>
		<label>Open the markets wide. Let trade flow freely.</label>
		<parentEvent>empireEvents_tradeSeason_0</parentEvent>
		<baseChanceOfSuccess>100</baseChanceOfSuccess>
		<silverCost>0</silverCost>
		<successEvent>empireEvents_tradeSeason_open</successEvent>
	</FactionColonies.FCOptionDef>

	<!-- Option B: Aggressive deals -->
	<FactionColonies.FCOptionDef>
		<defName>empireEvents_tradeSeason_opt2</defName>
		<label>Drive hard bargains. Extract every last coin from these merchants.</label>
		<parentEvent>empireEvents_tradeSeason_0</parentEvent>
		<baseChanceOfSuccess>100</baseChanceOfSuccess>
		<silverCost>0</silverCost>
		<successEvent>empireEvents_tradeSeason_aggressive</successEvent>
	</FactionColonies.FCOptionDef>

	<!-- Option C: Invest in infrastructure -->
	<FactionColonies.FCOptionDef>
		<defName>empireEvents_tradeSeason_opt3</defName>
		<label>Invest the trade profits into permanent market infrastructure.</label>
		<parentEvent>empireEvents_tradeSeason_0</parentEvent>
		<baseChanceOfSuccess>100</baseChanceOfSuccess>
		<silverCost>600</silverCost>
		<successEvent>empireEvents_tradeSeason_invest</successEvent>
	</FactionColonies.FCOptionDef>

	<!-- Outcome A: Open markets — standard bonuses -->
	<FactionColonies.FCEventDef>
		<defName>empireEvents_tradeSeason_open</defName>
		<label>Open Markets</label>
		<desc>Your settlements throw open their gates to trade. Merchants come and go freely, and the bustling commerce lifts spirits and fills coffers alike. A balanced approach that benefits everyone.</desc>
		<category>EC_Economy</category>
		<timeTillTrigger>600000</timeTillTrigger>
		<timeTillTriggerMax>900000</timeTillTriggerMax>
		<statModifiers>
			<li><stat>titheValueMultiplier</stat><value>1.1</value></li>
			<li><stat>taxBasePercentage</stat><value>0.05</value></li>
			<li><stat>happinessGainedBase</stat><value>0.5</value></li>
		</statModifiers>
		<targetAllSettlements>true</targetAllSettlements>
		<settlementsCarryOver>true</settlementsCarryOver>
		<incompatibleEvents>
			<li>empireEvents_tradeSeason_0</li>
		</incompatibleEvents>
	</FactionColonies.FCEventDef>

	<!-- Outcome B: Aggressive deals — double tax bonuses, loyalty penalty -->
	<FactionColonies.FCEventDef>
		<defName>empireEvents_tradeSeason_aggressive</defName>
		<label>Aggressive Trade</label>
		<desc>Your merchants drive ruthless bargains, squeezing maximum profit from every transaction. Tax revenue surges, but the predatory tactics leave a bitter taste. Citizens and visiting traders alike grumble about the empire's greed.</desc>
		<category>EC_Economy</category>
		<timeTillTrigger>600000</timeTillTrigger>
		<timeTillTriggerMax>900000</timeTillTriggerMax>
		<statModifiers>
			<li><stat>titheValueMultiplier</stat><value>1.2</value></li>
			<li><stat>taxBasePercentage</stat><value>0.1</value></li>
			<li><stat>loyaltyLostBase</stat><value>2</value></li>
		</statModifiers>
		<targetAllSettlements>true</targetAllSettlements>
		<settlementsCarryOver>true</settlementsCarryOver>
		<incompatibleEvents>
			<li>empireEvents_tradeSeason_0</li>
		</incompatibleEvents>
	</FactionColonies.FCEventDef>

	<!-- Outcome C: Invest — halved temporary bonuses, permanent tithe multiplier -->
	<FactionColonies.FCEventDef>
		<defName>empireEvents_tradeSeason_invest</defName>
		<label>Trade Infrastructure</label>
		<desc>Rather than chasing short-term gains, you funnel the season's profits into permanent market stalls, trade roads, and warehousing. The immediate benefits are modest, but the long-term improvements to trade efficiency will pay dividends for years.</desc>
		<category>EC_Economy</category>
		<timeTillTrigger>600000</timeTillTrigger>
		<timeTillTriggerMax>900000</timeTillTriggerMax>
		<statModifiers>
			<li><stat>titheValueMultiplier</stat><value>1.05</value></li>
			<li><stat>taxBasePercentage</stat><value>0.025</value></li>
		</statModifiers>
		<permanentStatModifiers>
			<li><stat>titheValueMultiplier</stat><value>1.05</value></li>
		</permanentStatModifiers>
		<targetAllSettlements>true</targetAllSettlements>
		<settlementsCarryOver>true</settlementsCarryOver>
		<incompatibleEvents>
			<li>empireEvents_tradeSeason_0</li>
		</incompatibleEvents>
	</FactionColonies.FCEventDef>

</Defs>
