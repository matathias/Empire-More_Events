<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_deserters_0</defName>
    <label>Deserters Offer Service</label>
    <desc>A group of soldiers from a hostile faction has defected and arrived at your borders. They claim to be disillusioned with their leaders and offer to serve in your military. Do you accept them?</desc>
    <category>EC_Military</category>
    <timeTillTrigger>0</timeTillTrigger>
    <activateAtStart>true</activateAtStart>
    <cooldownTicks>600000</cooldownTicks>
    <isRandomEvent>true</isRandomEvent>
    <weight>10</weight>
    <minDaysSinceFounded>10</minDaysSinceFounded>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_deserters_1a</li>
      <li>empireEvents_deserters_1b</li>
      <li>empireEvents_deserters_1d</li>
      <li>empireEvents_deserters_1e</li>
    </incompatibleEvents>
    <options>
      <li>empireEvents_deserters_opt1</li>
      <li>empireEvents_deserters_opt2</li>
      <li>empireEvents_deserters_opt3</li>
      <li>empireEvents_deserters_opt4</li>
      <li>empireEvents_deserters_opt5</li>
      <li>empireEvents_deserters_opt6</li>
    </options>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_deserters_opt1</defName>
    <label>Accept them into our ranks. We can use the manpower.</label>
    <parentEvent>empireEvents_deserters_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_deserters_1a</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_deserters_opt2</defName>
    <label>Accept them, but keep them under close watch.</label>
    <parentEvent>empireEvents_deserters_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_deserters_1b</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_deserters_opt3</defName>
    <label>Turn them away. Deserters can't be trusted.</label>
    <parentEvent>empireEvents_deserters_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_deserters_opt4</defName>
    <label>Our borders are closed to all outsiders. Send them away.</label>
    <parentEvent>empireEvents_deserters_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <requiredPolicies>
      <li>isolationist</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_deserters_opt5</defName>
    <label>Put them through military training. We'll know if they're spies.</label>
    <parentEvent>empireEvents_deserters_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>100</silverCost>
    <successEvent>empireEvents_deserters_1d</successEvent>
    <requiredPolicies>
      <li>militaristic</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_deserters_opt6</defName>
    <label>Collars and chains. They'll work.</label>
    <parentEvent>empireEvents_deserters_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_deserters_1e</successEvent>
    <requiredPolicies>
      <li>slaver</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_deserters_1a</defName>
    <label>Deserters Integrated</label>
    <desc>The deserters are folded into your military forces. Their combat experience bolsters your settlements' defenses significantly. But can they truly be trusted?</desc>
    <category>EC_Military</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_deserters_0</li>
    </incompatibleEvents>
    <followingEvent>empireEvents_deserters_spy</followingEvent>
    <splitEventFollows>true</splitEventFollows>
    <splitEventChance>35</splitEventChance>
    <statModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>2</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_deserters_spy</defName>
    <label>Spy Among Deserters</label>
    <desc>It was a trap. One of the deserters was a spy feeding intelligence back to their original faction. They've sabotaged defenses and sown confusion before being caught. Your settlements' military readiness takes a serious hit.</desc>
    <category>EC_Military</category>
    <timeTillTrigger>1500</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <eventFollows>true</eventFollows>
    <followingEvent>empireEvents_deserters_spy_followup</followingEvent>
    <statModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>-2</value>
      </li>
      <li>
        <stat>unrestGainedBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
    <modExtensions>
      <li Class="FactionColonies.FCEventHandlerExtension_TriggerAttack">
        <attackCount>1~2</attackCount>
      </li>
    </modExtensions>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_deserters_1b</defName>
    <label>Deserters (Under Watch)</label>
    <desc>The deserters serve under careful supervision. Their contribution is limited by the restrictions, but so is the potential for sabotage.</desc>
    <category>EC_Military</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_deserters_0</li>
    </incompatibleEvents>
    <eventFollows>true</eventFollows>
    <followingEvent>empireEvents_deserters_spy</followingEvent>
    <splitEventChance>20</splitEventChance>
    <statModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_deserters_1d</defName>
    <label>Deserters (Military Training)</label>
    <desc>The deserters are put through rigorous military training under close supervision. Your officers quickly identify the competent from the suspicious. The investment in training weeds out potential threats while producing capable soldiers.</desc>
    <category>EC_Military</category>
    <timeTillTrigger>900000</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_deserters_0</li>
    </incompatibleEvents>
    <followingEvent>empireEvents_deserters_spy</followingEvent>
    <splitEventFollows>true</splitEventFollows>
    <splitEventChance>10</splitEventChance>
    <statModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_deserters_1e</defName>
    <label>Deserters Enslaved</label>
    <desc>The deserters are stripped of their weapons and put in chains. Whatever intelligence they might have carried is irrelevant — they'll spend their days in the mines and fields.</desc>
    <category>EC_Military</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_deserters_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>workerBaseMax</stat>
        <value>2</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_deserters_spy_followup</defName>
    <label>Spy Among Deserters</label>
    <desc>It was a trap. One of the deserters was a spy feeding intelligence back to their original faction. They've sabotaged defenses and sown confusion before being caught. Your settlements' military readiness takes a serious hit.</desc>
    <category>EC_Military</category>
    <timeTillTrigger>180000</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <statModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>-2</value>
      </li>
      <li>
        <stat>unrestGainedBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

</Defs>
