<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_counterfeiting_0</defName>
    <label>Counterfeiting Ring</label>
    <desc>Reports are coming in from multiple settlements: counterfeit silver is flooding the local markets. Tax revenue is being undermined and merchants are growing suspicious of all currency. How do you respond?</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>0</timeTillTrigger>
    <activateAtStart>true</activateAtStart>
    <cooldownTicks>900000</cooldownTicks>
    <isRandomEvent>true</isRandomEvent>
    <weight>10</weight>
    <requiredWealth>15000</requiredWealth>
    <minDaysSinceFounded>15</minDaysSinceFounded>
    <rangeSettlementsAffected>2~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_counterfeiting_1a</li>
      <li>empireEvents_counterfeiting_1b</li>
      <li>empireEvents_counterfeiting_1c</li>
      <li>empireEvents_counterfeiting_1d</li>
      <li>empireEvents_counterfeiting_2</li>
    </incompatibleEvents>
    <options>
      <li>empireEvents_counterfeiting_opt1</li>
      <li>empireEvents_counterfeiting_opt2</li>
      <li>empireEvents_counterfeiting_opt3</li>
      <li>empireEvents_counterfeiting_opt6</li>
      <li>empireEvents_counterfeiting_opt7</li>
    </options>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_counterfeiting_opt1</defName>
    <label>Launch a formal investigation to track the counterfeiters.</label>
    <parentEvent>empireEvents_counterfeiting_0</parentEvent>
    <baseChanceOfSuccess>70</baseChanceOfSuccess>
    <silverCost>500</silverCost>
    <successEvent>empireEvents_counterfeiting_2</successEvent>
    <failEvent>empireEvents_counterfeiting_1a</failEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_counterfeiting_opt2</defName>
    <label>Crack down hard. Search every market stall and warehouse.</label>
    <parentEvent>empireEvents_counterfeiting_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>250</silverCost>
    <successEvent>empireEvents_counterfeiting_1b</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_counterfeiting_opt3</defName>
    <label>It will sort itself out. We have bigger concerns.</label>
    <parentEvent>empireEvents_counterfeiting_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_counterfeiting_1c</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_counterfeiting_opt6</defName>
    <label>Round up the suspects. No trial needed.</label>
    <parentEvent>empireEvents_counterfeiting_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_counterfeiting_1d</successEvent>
    <requiredPolicies>
      <li>authoritarian</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_counterfeiting_opt7</defName>
    <label>Our financial experts can trace the forgeries.</label>
    <parentEvent>empireEvents_counterfeiting_0</parentEvent>
    <baseChanceOfSuccess>85</baseChanceOfSuccess>
    <silverCost>300</silverCost>
    <successEvent>empireEvents_counterfeiting_2</successEvent>
    <failEvent>empireEvents_counterfeiting_1a</failEvent>
    <requiredPolicies>
      <li>mercantile</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_counterfeiting_1a</defName>
    <label>Investigation Failed</label>
    <desc>Your investigators turned up nothing; the counterfeit silver continues to circulate. Nevertheless, the investigation spooked the perpetrators, who slowly cease operations on their own.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <timeTillTriggerMax>450000</timeTillTriggerMax>
    <rangeSettlementsAffected>2~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_counterfeiting_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>taxBasePercentage</stat>
        <value>-10</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_counterfeiting_1b</defName>
    <label>Market Crackdown</label>
    <desc>Your aggressive raids disrupt the counterfeiting operation but also the daily lives of ordinary citizens. Markets are closed, merchants harassed, and the people grow resentful of the heavy-handed approach.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>150000</timeTillTrigger>
    <rangeSettlementsAffected>2~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_counterfeiting_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>taxBasePercentage</stat>
        <value>-10</value>
      </li>
      <li>
        <stat>happinessGainedBase</stat>
        <value>-2</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_counterfeiting_1c</defName>
    <label>Unchecked Counterfeiting</label>
    <desc>Without intervention, the counterfeit silver runs its course through the economy. The counterfeiters grow brazen. Tax revenues suffer until the forgeries naturally thin out.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <rangeSettlementsAffected>2~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_counterfeiting_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>taxBasePercentage</stat>
        <value>-20</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_counterfeiting_1d</defName>
    <label>Suspects Rounded Up</label>
    <desc>Soldiers sweep through the settlements, arresting anyone connected to the counterfeiting ring — and a few who weren't. The operation is shut down overnight. Citizens are uneasy about the summary justice, but the currency is secure.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>120000</timeTillTrigger>
    <timeTillTriggerMax>300000</timeTillTriggerMax>
    <rangeSettlementsAffected>2~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_counterfeiting_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>unrestGainedBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_counterfeiting_2</defName>
    <label>Counterfeiting Ring Exposed</label>
    <desc>Your investigators have traced the counterfeit silver to its source: a well-organized ring operating out of a local warehouse. You have them cornered. What do you do with them?</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>0</timeTillTrigger>
    <activateAtStart>true</activateAtStart>
    <rangeSettlementsAffected>2~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_counterfeiting_0</li>
    </incompatibleEvents>
    <options>
      <li>empireEvents_counterfeiting_opt4</li>
      <li>empireEvents_counterfeiting_opt5</li>
    </options>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_counterfeiting_opt4</defName>
    <label>Arrest them all and make a public example.</label>
    <parentEvent>empireEvents_counterfeiting_2</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_counterfeiting_2a</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_counterfeiting_opt5</defName>
    <label>Offer them a deal: they work for us now, minting legitimate currency.</label>
    <parentEvent>empireEvents_counterfeiting_2</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_counterfeiting_2b</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_counterfeiting_2a</defName>
    <label>Counterfeiters Arrested</label>
    <desc>The counterfeiters are hauled before the public and punished. The disruption caused by the counterfeiting won't disappear overnight, but your people are happy to know that your currency is secure.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>120000</timeTillTrigger>
    <timeTillTriggerMax>240000</timeTillTriggerMax>
    <rangeSettlementsAffected>2~3</rangeSettlementsAffected>
    <statModifiers>
      <li>
        <stat>happinessGainedBase</stat>
        <value>1</value>
      </li>
      <li>
        <stat>taxBasePercentage</stat>
        <value>-5</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_counterfeiting_2b</defName>
    <label>Imperial Minters</label>
    <desc>The former counterfeiters now work for the empire, lending their expertise to improve currency production. Tax collection improves noticeably, though some whisper about the arrangement's legitimacy.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <rangeSettlementsAffected>2~3</rangeSettlementsAffected>
    <followingEvent>empireEvents_counterfeiting_scandal</followingEvent>
    <splitEventFollows>true</splitEventFollows>
    <splitEventChance>30</splitEventChance>
    <statModifiers>
      <li>
        <stat>taxBasePercentage</stat>
        <value>5</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_counterfeiting_scandal</defName>
    <label>Minting Scandal</label>
    <desc>Word has gotten out that the empire recruited known counterfeiters into its treasury. Citizens question the integrity of the currency and the leadership's judgment. Loyalty suffers and tax collection dips.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>180000</timeTillTrigger>
    <timeTillTriggerMax>300000</timeTillTriggerMax>
    <rangeSettlementsAffected>2~3</rangeSettlementsAffected>
    <statModifiers>
      <li>
        <stat>taxBasePercentage</stat>
        <value>-5</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>-2</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

</Defs>
