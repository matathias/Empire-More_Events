    <incompatibleEvents>
      <li>empireEvents_goldenAge</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>titheValueMultiplier</stat>
        <value>1.2</value>
      </li>
      <li>
        <stat>happinessGainedBase</stat>
        <value>1</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

</Defs>
