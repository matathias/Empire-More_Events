<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_earthquake_0</defName>
    <label>Earthquake</label>
    <desc>A violent earthquake has struck your settlements! Mines have collapsed, buildings are damaged, and workers are injured. The damage is significant. How do you respond to the crisis?</desc>
    <category>EC_Settlement</category>
    <isNegative>true</isNegative>
    <timeTillTrigger>0</timeTillTrigger>
    <activateAtStart>true</activateAtStart>
    <cooldownTicks>1800000</cooldownTicks>
    <isRandomEvent>true</isRandomEvent>
    <weight>10</weight>
    <minDaysSinceFounded>5</minDaysSinceFounded>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <proximityFalloff>5</proximityFalloff>
    <incompatibleEvents>
      <li>empireEvents_earthquake_1a</li>
      <li>empireEvents_earthquake_1b</li>
      <li>empireEvents_earthquake_1c</li>
      <li>empireEvents_earthquake_1d</li>
    </incompatibleEvents>
    <options>
      <li>empireEvents_earthquake_opt1</li>
      <li>empireEvents_earthquake_opt2</li>
      <li>empireEvents_earthquake_opt3</li>
      <li>empireEvents_earthquake_opt4</li>
      <li>empireEvents_earthquake_opt5</li>
    </options>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_earthquake_opt1</defName>
    <label>Launch an emergency relief effort. Get our people the help they need.</label>
    <parentEvent>empireEvents_earthquake_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>600</silverCost>
    <successEvent>empireEvents_earthquake_1a</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_earthquake_opt2</defName>
    <label>Invest in rebuilding with better materials. We won't be caught off guard again.</label>
    <parentEvent>empireEvents_earthquake_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>300</silverCost>
    <successEvent>empireEvents_earthquake_1b</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_earthquake_opt3</defName>
    <label>They'll manage. We can't afford to divert resources right now.</label>
    <parentEvent>empireEvents_earthquake_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_earthquake_1c</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_earthquake_opt4</defName>
    <label>Our contingency plans are already in motion.</label>
    <parentEvent>empireEvents_earthquake_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>200</silverCost>
    <successEvent>empireEvents_earthquake_1a</successEvent>
    <requiredPolicies>
      <li>resilient</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_earthquake_opt5</defName>
    <label>Put every available worker on repairs.</label>
    <parentEvent>empireEvents_earthquake_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_earthquake_1d</successEvent>
    <requiredPolicies>
      <li>industrious</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_earthquake_1a</defName>
    <label>Earthquake Recovery (Relief)</label>
    <desc>Emergency supplies and work crews are dispatched immediately. The swift response limits the damage and lifts spirits; citizens feel cared for by their leaders.</desc>
    <category>EC_Settlement</category>
    <timeTillTrigger>180000</timeTillTrigger>
    <timeTillTriggerMax>300000</timeTillTriggerMax>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_earthquake_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>-0.5</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>2</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_earthquake_1b</defName>
    <label>Earthquake Recovery (Rebuilding)</label>
    <desc>Rather than quick fixes, your settlements invest in proper reconstruction with reinforced materials. The recovery is slow and painful, but the end result will be infrastructure better than before.</desc>
    <category>EC_Settlement</category>
    <timeTillTrigger>180000</timeTillTrigger>
    <timeTillTriggerMax>300000</timeTillTriggerMax>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_earthquake_0</li>
    </incompatibleEvents>
    <eventFollows>true</eventFollows>
    <followingEvent>empireEvents_earthquake_rebuilt</followingEvent>
    <statModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>-1</value>
      </li>
      <li>
        <stat>workerBaseMax</stat>
        <value>-1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_earthquake_rebuilt</defName>
    <label>Reconstruction Complete</label>
    <desc>The rebuilding effort is finished. New mining infrastructure is stronger and more efficient than what stood before.</desc>
    <category>EC_Construction</category>
    <timeTillTrigger>1500</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <permanentStatModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>0.5</value>
      </li>
    </permanentStatModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_earthquake_1c</defName>
    <label>Earthquake Aftermath</label>
    <desc>Without aid from the capital, your settlements struggle to recover on their own. Workers dig through rubble with bare hands. The lack of response breeds resentment — citizens feel abandoned by their rulers.</desc>
    <category>EC_Settlement</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <timeTillTriggerMax>600000</timeTillTriggerMax>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_earthquake_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>-1</value>
      </li>
      <li>
        <stat>workerBaseMax</stat>
        <value>-1</value>
      </li>
      <li>
        <stat>unrestGainedBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_earthquake_1d</defName>
    <label>Earthquake Recovery (Work Crews)</label>
    <desc>Your industrious workforce mobilizes immediately, clearing rubble and shoring up damaged structures with practiced efficiency. The mining disruption is minimal; these people know how to rebuild.</desc>
    <category>EC_Settlement</category>
    <timeTillTrigger>120000</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_earthquake_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>-0.5</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

</Defs>
