<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_prospectorsBoom_0</defName>
    <label>Prospector's Boom</label>
    <desc>Prospectors have struck rich mineral veins near your settlements! Word spreads fast and eager miners flood into the area, ready to dig. The deposits are substantial, but we need to determine how to extract them.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>0</timeTillTrigger>
    <activateAtStart>true</activateAtStart>
    <cooldownTicks>1800000</cooldownTicks>
    <isRandomEvent>true</isRandomEvent>
    <weight>10</weight>
    <rangeSettlementsAffected>1~3</rangeSettlementsAffected>
    <requiredResource>RTD_Mining</requiredResource>
    <incompatibleEvents>
      <li>empireEvents_prospectorsBoom_regulate</li>
      <li>empireEvents_prospectorsBoom_freeForAll</li>
      <li>empireEvents_prospectorsBoom_controlled</li>
      <li>empireEvents_prospectorsBoom_coop</li>
      <li>empireEvents_prospectorsBoom_forced</li>
    </incompatibleEvents>
    <options>
      <li>empireEvents_prospectorsBoom_opt1</li>
      <li>empireEvents_prospectorsBoom_opt2</li>
      <li>empireEvents_prospectorsBoom_opt3</li>
      <li>empireEvents_prospectorsBoom_opt_egalitarian</li>
      <li>empireEvents_prospectorsBoom_opt_slaver</li>
    </options>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_prospectorsBoom_opt1</defName>
    <label>Regulate the extraction. Orderly mining, fair distribution.</label>
    <parentEvent>empireEvents_prospectorsBoom_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_prospectorsBoom_regulate</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_prospectorsBoom_opt2</defName>
    <label>Let anyone dig. First come, first served — maximum yield.</label>
    <parentEvent>empireEvents_prospectorsBoom_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_prospectorsBoom_freeForAll</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_prospectorsBoom_opt3</defName>
    <label>Invest in proper mining infrastructure for long-term gain.</label>
    <parentEvent>empireEvents_prospectorsBoom_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>300</silverCost>
    <successEvent>empireEvents_prospectorsBoom_controlled</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_prospectorsBoom_opt_egalitarian</defName>
    <label>Establish a community mining cooperative. The profits belong to everyone.</label>
    <parentEvent>empireEvents_prospectorsBoom_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_prospectorsBoom_coop</successEvent>
    <requiredPolicies>
      <li>egalitarian</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_prospectorsBoom_opt_slaver</defName>
    <label>Conscript laborers for the mines. We need output, not comfort.</label>
    <parentEvent>empireEvents_prospectorsBoom_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_prospectorsBoom_forced</successEvent>
    <requiredPolicies>
      <li>slaver</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_prospectorsBoom_regulate</defName>
    <label>Regulated Mining Boom</label>
    <desc>Under careful regulation, the mining boom proceeds in an orderly fashion. Output is strong, new workers join the settlements, and while the grueling labor dampens spirits somewhat, the overall impact is solidly positive.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <rangeSettlementsAffected>1~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_prospectorsBoom_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>2</value>
      </li>
      <li>
        <stat>workerBaseMax</stat>
        <value>1</value>
      </li>
      <li>
        <stat>happinessLostBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_prospectorsBoom_freeForAll</defName>
    <label>Mining Frenzy</label>
    <desc>The unregulated rush for minerals turns your settlements into chaotic boomtowns. Mining output is extraordinary, but the lawless atmosphere breeds crime, injury, and bitter disputes over claims. Workers pour in, but happiness plummets and unrest rises.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <rangeSettlementsAffected>1~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_prospectorsBoom_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>3</value>
      </li>
      <li>
        <stat>workerBaseMax</stat>
        <value>1</value>
      </li>
      <li>
        <stat>happinessLostBase</stat>
        <value>2.5</value>
      </li>
      <li>
        <stat>unrestGainedBase</stat>
        <value>1.5</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_prospectorsBoom_controlled</defName>
    <label>Mining Infrastructure</label>
    <desc>Your investment builds proper mine shafts, ore processing facilities, and safety equipment. The immediate yield is modest as resources go toward construction, but the infrastructure ensures that these deposits will be producing ore long after the boom fades.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <rangeSettlementsAffected>1~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_prospectorsBoom_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>1</value>
      </li>
      <li>
        <stat>workerBaseMax</stat>
        <value>1</value>
      </li>
      <li>
        <stat>happinessLostBase</stat>
        <value>0.5</value>
      </li>
    </statModifiers>
    <permanentStatModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>0.25</value>
      </li>
    </permanentStatModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_prospectorsBoom_coop</defName>
    <label>Mining Cooperative</label>
    <desc>A community-owned mining cooperative is established. Every worker has an equal share in the profits, and the democratic structure ensures fair treatment and reasonable hours. Output is strong — not as extreme as an unregulated rush, but sustained and steady. Best of all, the shared prosperity means no one resents the work.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <rangeSettlementsAffected>1~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_prospectorsBoom_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>1.5</value>
      </li>
      <li>
        <stat>workerBaseMax</stat>
        <value>1</value>
      </li>
      <li>
        <stat>happinessGainedBase</stat>
        <value>0.5</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_prospectorsBoom_forced</defName>
    <label>Forced Mining</label>
    <desc>Conscripted laborers are marched to the mines under armed guard. The output is extraordinary — every vein is exploited, every shaft extended to its limit. Additional workers are pressed into service from surrounding settlements.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <rangeSettlementsAffected>1~3</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_prospectorsBoom_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Mining_ProductionAdditive</stat>
        <value>3</value>
      </li>
      <li>
        <stat>workerBaseMax</stat>
        <value>2</value>
      </li>
      <li>
        <stat>happinessLostBase</stat>
        <value>2</value>
      </li>
      <li>
        <stat>unrestGainedBase</stat>
        <value>2</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

</Defs>
