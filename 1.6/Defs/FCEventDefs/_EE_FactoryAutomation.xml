<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_factoryAutomation_0</defName>
    <label>Factory Automation</label>
    <desc>Engineers at your settlements have developed plans for automating key production lines. The technology is ready; the question is how far to take it. Full automation would boost output dramatically, but it would also eliminate jobs. Workers are already nervous. How do you proceed?</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>0</timeTillTrigger>
    <activateAtStart>true</activateAtStart>
    <cooldownTicks>1800000</cooldownTicks>
    <isRandomEvent>true</isRandomEvent>
    <weight>10</weight>
    <requiredWealth>25000</requiredWealth>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <requiredResource>RTD_Power</requiredResource>
    <minTechLevel>Spacer</minTechLevel>
    <incompatibleEvents>
      <li>empireEvents_factoryAutomation_1a</li>
      <li>empireEvents_factoryAutomation_1a_transhumanist</li>
      <li>empireEvents_factoryAutomation_1b</li>
      <li>empireEvents_factoryAutomation_1c</li>
      <li>empireEvents_factoryAutomation_1c_naturePrimacy</li>
      <li>empireEvents_factoryAutomation_1d</li>
    </incompatibleEvents>
    <options>
      <li>empireEvents_factoryAutomation_opt1</li>
      <li>empireEvents_factoryAutomation_opt_transhumanist</li>
      <li>empireEvents_factoryAutomation_opt2</li>
      <li>empireEvents_factoryAutomation_opt3</li>
      <li>empireEvents_factoryAutomation_opt_naturePrimacy</li>
      <li>empireEvents_factoryAutomation_opt4</li>
    </options>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_factoryAutomation_opt1</defName>
    <label>Automate everything. Machines don't complain or take breaks.</label>
    <parentEvent>empireEvents_factoryAutomation_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>3000</silverCost>
    <successEvent>empireEvents_factoryAutomation_1a</successEvent>
    <modExtensions>
      <li Class="FactionColonies.FCDynamicCostExtension">
        <costPerEmpireIncomeUnit>0.04</costPerEmpireIncomeUnit>
      </li>
    </modExtensions>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_factoryAutomation_opt2</defName>
    <label>Automate the most dangerous tasks. Keep workers for everything else.</label>
    <parentEvent>empireEvents_factoryAutomation_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>1500</silverCost>
    <successEvent>empireEvents_factoryAutomation_1b</successEvent>
    <modExtensions>
      <li Class="FactionColonies.FCDynamicCostExtension">
        <costPerEmpireIncomeUnit>0.04</costPerEmpireIncomeUnit>
      </li>
    </modExtensions>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_factoryAutomation_opt3</defName>
    <label>Shelve the plans. Our workers are our strength, not machines.</label>
    <parentEvent>empireEvents_factoryAutomation_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_factoryAutomation_1c</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_factoryAutomation_opt4</defName>
    <label>Phase it in gradually. Retrain workers as machine operators.</label>
    <parentEvent>empireEvents_factoryAutomation_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>2000</silverCost>
    <successEvent>empireEvents_factoryAutomation_1d</successEvent>
    <requiredPolicies>
      <li>industrious</li>
    </requiredPolicies>
    <modExtensions>
      <li Class="FactionColonies.FCDynamicCostExtension">
        <costPerEmpireIncomeUnit>0.04</costPerEmpireIncomeUnit>
      </li>
    </modExtensions>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_factoryAutomation_opt_transhumanist</defName>
    <label>Automate everything — and merge our people with the machines. Worker and tool, one and the same.</label>
    <parentEvent>empireEvents_factoryAutomation_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>3000</silverCost>
    <successEvent>empireEvents_factoryAutomation_1a_transhumanist</successEvent>
    <requiredMemes>
      <li>Transhumanist</li>
    </requiredMemes>
    <modExtensions>
      <li Class="FactionColonies.FCDynamicCostExtension">
        <costPerEmpireIncomeUnit>0.04</costPerEmpireIncomeUnit>
      </li>
    </modExtensions>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_factoryAutomation_opt_naturePrimacy</defName>
    <label>Burn the blueprints. Honest hands and honest craft built this nation — not soulless machines.</label>
    <parentEvent>empireEvents_factoryAutomation_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_factoryAutomation_1c_naturePrimacy</successEvent>
    <requiredMemes>
      <li>NaturePrimacy</li>
    </requiredMemes>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_factoryAutomation_1a</defName>
    <label>Full Automation</label>
    <desc>The factories hum with mechanical precision as automated systems replace manual labor across the board. Production surges, but displaced workers flood the streets. The settlement's workforce capacity is permanently reduced as entire job categories cease to exist.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <timeTillTriggerMax>600000</timeTillTriggerMax>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_factoryAutomation_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>unrestGainedBase</stat>
        <value>1</value>
      </li>
      <li>
        <stat>happinessLostBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
    <permanentStatModifiers>
      <li>
        <stat>workerProductionMultiplier</stat>
        <value>1.5</value>
      </li>
      <li>
        <stat>workerBaseMax</stat>
        <value>-5</value>
      </li>
    </permanentStatModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_factoryAutomation_1b</defName>
    <label>Partial Automation</label>
    <desc>Dangerous and repetitive tasks are handed off to machines while skilled workers handle the rest. It's a balanced approach — productivity increases noticeably, and workers appreciate not having to risk their lives on the factory floor. The boost lasts while the new equipment is at peak performance.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_factoryAutomation_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>workerProductionMultiplier</stat>
        <value>1.25</value>
      </li>
      <li>
        <stat>workerBaseMax</stat>
        <value>-1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_factoryAutomation_1c</defName>
    <label>Automation Rejected</label>
    <desc>The automation plans are publicly shelved, and workers celebrate. Your decision to value human labor over mechanical efficiency earns deep loyalty and a surge of morale. Productivity may not have improved, but your people know you stand with them.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_factoryAutomation_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>happinessGainedBase</stat>
        <value>1</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_factoryAutomation_1d</defName>
    <label>Phased Rollout</label>
    <desc>Under the careful guidance of your industrious administration, automation is introduced gradually. Workers are retrained as machine operators and maintenance technicians rather than replaced. The transition takes time, but the result is a permanent increase in productivity with no loss of workforce. A masterful balance of progress and pragmatism.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>1500</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_factoryAutomation_0</li>
    </incompatibleEvents>
    <permanentStatModifiers>
      <li>
        <stat>workerProductionMultiplier</stat>
        <value>1.35</value>
      </li>
    </permanentStatModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_factoryAutomation_1a_transhumanist</defName>
    <label>Human-Machine Synthesis</label>
    <desc>There are no displaced workers, because there is no line between worker and machine. Neural interfaces and powered exoframes turn every laborer into something more — tireless, precise, exultant. Output soars, and your people do not mourn the old ways. They have become the future they were promised, and they wear it with pride.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>1500</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_factoryAutomation_0</li>
    </incompatibleEvents>
    <permanentStatModifiers>
      <li>
        <stat>workerProductionMultiplier</stat>
        <value>1.5</value>
      </li>
      <li>
        <stat>happinessGainedBase</stat>
        <value>0.5</value>
      </li>
    </permanentStatModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_factoryAutomation_1c_naturePrimacy</defName>
    <label>The Craft Endures</label>
    <desc>The blueprints are burned in the town square to roaring approval. Your settlements recommit to the dignity of human hands and the honest rhythm of craft over the cold efficiency of the machine. It is a defining declaration of who your people are, and their devotion to your {FACTION_TITLE} deepens for good.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>1500</timeTillTrigger>
    <rangeSettlementsAffected>1~2</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_factoryAutomation_0</li>
    </incompatibleEvents>
    <permanentStatModifiers>
      <li>
        <stat>happinessGainedBase</stat>
        <value>1</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>0.5</value>
      </li>
    </permanentStatModifiers>
  </FactionColonies.FCEventDef>

</Defs>
