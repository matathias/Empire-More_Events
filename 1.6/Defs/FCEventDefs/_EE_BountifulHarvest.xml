<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_bountifulHarvest_0</defName>
    <label>Bountiful Harvest Season</label>
    <desc>An unusually fertile season has blessed your settlements with abundant crops. Fields overflow with produce, and granaries are filling faster than anyone anticipated. How do you use the surplus?</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>0</timeTillTrigger>
    <activateAtStart>true</activateAtStart>
    <cooldownTicks>1800000</cooldownTicks>
    <isRandomEvent>true</isRandomEvent>
    <weight>15</weight>
    <targetAllSettlements>true</targetAllSettlements>
    <restrictedBiomes>
      <li>IceSheet</li>
      <li>SeaIce</li>
    </restrictedBiomes>
    <requiredResource>RTD_Food</requiredResource>
    <incompatibleEvents>
      <li>empireEvents_bountifulHarvest_store</li>
      <li>empireEvents_bountifulHarvest_feast</li>
      <li>empireEvents_bountifulHarvest_sell</li>
      <li>empireEvents_bountifulHarvest_share</li>
      <li>empireEvents_bountifulHarvest_forced</li>
    </incompatibleEvents>
    <options>
      <li>empireEvents_bountifulHarvest_opt1</li>
      <li>empireEvents_bountifulHarvest_opt2</li>
      <li>empireEvents_bountifulHarvest_opt3</li>
      <li>empireEvents_bountifulHarvest_opt_pacifist</li>
      <li>empireEvents_bountifulHarvest_opt_slaver</li>
    </options>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_bountifulHarvest_opt1</defName>
    <label>Store the surplus. Build up our reserves for harder times.</label>
    <parentEvent>empireEvents_bountifulHarvest_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_bountifulHarvest_store</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_bountifulHarvest_opt2</defName>
    <label>Declare a harvest feast! Let the people celebrate abundance.</label>
    <parentEvent>empireEvents_bountifulHarvest_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_bountifulHarvest_feast</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_bountifulHarvest_opt3</defName>
    <label>Sell the surplus at market. Turn food into silver.</label>
    <parentEvent>empireEvents_bountifulHarvest_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_bountifulHarvest_sell</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_bountifulHarvest_opt_pacifist</defName>
    <label>Share surplus with struggling neighboring factions. Goodwill buys more than grain.</label>
    <parentEvent>empireEvents_bountifulHarvest_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_bountifulHarvest_share</successEvent>
    <requiredPolicies>
      <li>pacifist</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_bountifulHarvest_opt_slaver</defName>
    <label>Double the harvest quotas. Work them until the fields are bare.</label>
    <parentEvent>empireEvents_bountifulHarvest_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_bountifulHarvest_forced</successEvent>
    <requiredPolicies>
      <li>slaver</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_bountifulHarvest_store</defName>
    <label>Harvest Stored</label>
    <desc>The bountiful harvest is carefully preserved and stored. Granaries swell with produce, and your settlements enjoy increased food production and a general sense of well-being from the abundance.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <timeTillTriggerMax>600000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_bountifulHarvest_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Food_ProductionAdditive</stat>
        <value>1</value>
      </li>
      <li>
        <stat>happinessGainedBase</stat>
        <value>0.5</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_bountifulHarvest_feast</defName>
    <label>Harvest Feast</label>
    <desc>Tables groan under the weight of the feast. Music and laughter echo across every settlement as citizens celebrate the bountiful season. The festivities consume much of the surplus, but the joy and solidarity they bring are priceless.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <timeTillTriggerMax>600000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_bountifulHarvest_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Food_ProductionAdditive</stat>
        <value>0.5</value>
      </li>
      <li>
        <stat>happinessGainedBase</stat>
        <value>1</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>0.5</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_bountifulHarvest_sell</defName>
    <label>Harvest Sold</label>
    <desc>Shipments of surplus produce head to market, where demand is high and prices are favorable. The food bonus is diminished, but your treasury benefits handsomely from the trade.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <timeTillTriggerMax>600000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_bountifulHarvest_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Food_ProductionAdditive</stat>
        <value>0.25</value>
      </li>
      <li>
        <stat>taxBasePercentage</stat>
        <value>10</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_bountifulHarvest_share</defName>
    <label>Harvest Shared</label>
    <desc>Shipments of surplus food are sent to struggling communities across the region. The generosity is noticed and appreciated — your {FACTION_TITLE}'s reputation as a benevolent neighbor grows. Citizens take pride in their collective charity.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <timeTillTriggerMax>600000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_bountifulHarvest_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Food_ProductionAdditive</stat>
        <value>0.25</value>
      </li>
      <li>
        <stat>happinessGainedBase</stat>
        <value>1</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_bountifulHarvest_forced</defName>
    <label>Forced Harvest</label>
    <desc>Overseers crack whips as laborers work the fields from dawn to dusk and beyond. The harvest yield is extraordinary — every grain is collected, every field stripped bare. Additional workers are pressed into service to handle the volume. But the brutality of the operation leaves its mark on morale.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <timeTillTriggerMax>600000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_bountifulHarvest_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>RTD_Food_ProductionAdditive</stat>
        <value>1</value>
      </li>
      <li>
        <stat>happinessLostBase</stat>
        <value>1</value>
      </li>
      <li>
        <stat>workerBaseMax</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

</Defs>
