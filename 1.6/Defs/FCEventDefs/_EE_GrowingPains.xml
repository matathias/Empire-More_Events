<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_growingPains_0</defName>
    <label>Growing Pains</label>
    <desc>Your empire is growing faster than its administrative infrastructure can handle. Officials are overwhelmed, leading to inefficient tax collection and sluggish military coordination. How do you address the bureaucratic strain?</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>0</timeTillTrigger>
    <activateAtStart>true</activateAtStart>
    <rangeSettlementsAffected>1~99</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_growingPains_admins</li>
      <li>empireEvents_growingPains_decentral</li>
      <li>empireEvents_growingPains_tighten</li>
      <li>empireEvents_growingPains_authoritarian</li>
      <li>empireEvents_growingPains_expansionist</li>
    </incompatibleEvents>
    <options>
      <li>empireEvents_growingPains_opt1</li>
      <li>empireEvents_growingPains_opt2</li>
      <li>empireEvents_growingPains_opt3</li>
      <li>empireEvents_growingPains_opt4</li>
      <li>empireEvents_growingPains_opt5</li>
    </options>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_growingPains_opt1</defName>
    <label>Hire experienced administrators to manage the growth.</label>
    <parentEvent>empireEvents_growingPains_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>800</silverCost>
    <successEvent>empireEvents_growingPains_admins</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_growingPains_opt2</defName>
    <label>Give local leaders more autonomy to manage their own affairs.</label>
    <parentEvent>empireEvents_growingPains_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_growingPains_decentral</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_growingPains_opt3</defName>
    <label>Tighten central control. Every decision goes through us.</label>
    <parentEvent>empireEvents_growingPains_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_growingPains_tighten</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_growingPains_opt4</defName>
    <label>The bureaucracy answers to us. Remind them.</label>
    <parentEvent>empireEvents_growingPains_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_growingPains_authoritarian</successEvent>
    <requiredPolicies>
      <li>authoritarian</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_growingPains_opt5</defName>
    <label>We've planned for this growth.</label>
    <parentEvent>empireEvents_growingPains_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_growingPains_expansionist</successEvent>
    <requiredPolicies>
      <li>expansionist</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_growingPains_admins</defName>
    <label>Administrative Expansion</label>
    <desc>New administrators are hired and deployed. The growing pains ease as experienced managers take on the workload.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <rangeSettlementsAffected>1~99</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_growingPains_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>taxBasePercentage</stat>
        <value>-5</value>
      </li>
      <li>
        <stat>militaryCombatEfficiency</stat>
        <value>0.95</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_growingPains_decentral</defName>
    <label>Decentralized Administration</label>
    <desc>Local leaders are given authority over day-to-day operations. Tax collection improves as locals know their markets, but military coordination suffers without central command.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <rangeSettlementsAffected>1~99</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_growingPains_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>taxBasePercentage</stat>
        <value>-5</value>
      </li>
      <li>
        <stat>militaryCombatEfficiency</stat>
        <value>0.9</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_growingPains_tighten</defName>
    <label>Tightened Control</label>
    <desc>Central authority clamps down on all administrative functions. Tax collection remains efficient, but the rigid control breeds resentment among citizens who feel micromanaged.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <rangeSettlementsAffected>1~99</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_growingPains_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>unrestGainedBase</stat>
        <value>2</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_growingPains_authoritarian</defName>
    <label>Iron Bureaucracy</label>
    <desc>Under your authoritarian mandate, the bureaucracy falls in line with ruthless efficiency. There is no tax penalty, but the heavy-handed approach generates some unrest.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <rangeSettlementsAffected>1~99</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_growingPains_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>unrestGainedBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_growingPains_expansionist</defName>
    <label>Planned Growth</label>
    <desc>Your empire's expansion plans accounted for this level of growth. Experienced administrators from earlier settlements train the new ones, and the transition is relatively smooth.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>300000</timeTillTrigger>
    <rangeSettlementsAffected>1~99</rangeSettlementsAffected>
    <incompatibleEvents>
      <li>empireEvents_growingPains_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>taxBasePercentage</stat>
        <value>-5</value>
      </li>
      <li>
        <stat>militaryCombatEfficiency</stat>
        <value>0.95</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

</Defs>
