<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_militaryRenaissance_0</defName>
    <label>Military Renaissance</label>
    <desc>A surge of martial enthusiasm sweeps through {FACTION}. Veteran soldiers share tales of glory, inspiring young recruits to train with unprecedented fervor as smiths work overtime forging weapons and armor. Your military has never been stronger — but where do you direct this energy?</desc>
    <category>EC_Military</category>
    <timeTillTrigger>0</timeTillTrigger>
    <activateAtStart>true</activateAtStart>
    <cooldownTicks>1800000</cooldownTicks>
    <isRandomEvent>true</isRandomEvent>
    <weight>10</weight>
    <minSettlements>3</minSettlements>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_militaryRenaissance_channel</li>
      <li>empireEvents_militaryRenaissance_wargames</li>
      <li>empireEvents_militaryRenaissance_training</li>
      <li>empireEvents_militaryRenaissance_civic</li>
      <li>empireEvents_militaryRenaissance_tournament</li>
      <li>empireEvents_militaryRenaissance_raids</li>
    </incompatibleEvents>
    <options>
      <li>empireEvents_militaryRenaissance_opt1</li>
      <li>empireEvents_militaryRenaissance_opt2</li>
      <li>empireEvents_militaryRenaissance_opt3</li>
      <li>empireEvents_militaryRenaissance_opt_pacifist</li>
      <li>empireEvents_militaryRenaissance_opt_feudal</li>
      <li>empireEvents_militaryRenaissance_opt_raiders</li>
    </options>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_militaryRenaissance_opt1</defName>
    <label>Channel this energy into strengthening our existing forces.</label>
    <parentEvent>empireEvents_militaryRenaissance_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_militaryRenaissance_channel</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_militaryRenaissance_opt2</defName>
    <label>Hold war games across the nation. Test our mettle in mock battles.</label>
    <parentEvent>empireEvents_militaryRenaissance_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>750</silverCost>
    <successEvent>empireEvents_militaryRenaissance_wargames</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_militaryRenaissance_opt3</defName>
    <label>Invest in permanent training facilities and doctrine.</label>
    <parentEvent>empireEvents_militaryRenaissance_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>750</silverCost>
    <successEvent>empireEvents_militaryRenaissance_training</successEvent>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_militaryRenaissance_opt_pacifist</defName>
    <label>Redirect this energy into civic works. Swords into plowshares.</label>
    <parentEvent>empireEvents_militaryRenaissance_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_militaryRenaissance_civic</successEvent>
    <requiredPolicies>
      <li>pacifist</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_militaryRenaissance_opt_feudal</defName>
    <label>Hold a grand tournament. Let our champions compete for honor and glory.</label>
    <parentEvent>empireEvents_militaryRenaissance_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <silverCost>500</silverCost>
    <successEvent>empireEvents_militaryRenaissance_tournament</successEvent>
    <requiredPolicies>
      <li>feudal</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCOptionDef>
    <defName>empireEvents_militaryRenaissance_opt_raiders</defName>
    <label>Point this energy outward. Let them raid our enemies.</label>
    <parentEvent>empireEvents_militaryRenaissance_0</parentEvent>
    <baseChanceOfSuccess>100</baseChanceOfSuccess>
    <successEvent>empireEvents_militaryRenaissance_raids</successEvent>
    <requiredPolicies>
      <li>raiders</li>
    </requiredPolicies>
  </FactionColonies.FCOptionDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_militaryRenaissance_channel</defName>
    <label>Military Surge</label>
    <desc>The martial enthusiasm is channeled into a focused strengthening of your forces. Soldiers train harder, equipment is maintained with care, and a palpable sense of loyalty and purpose pervades the ranks.</desc>
    <category>EC_Military</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_militaryRenaissance_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>1</value>
      </li>
      <li>
        <stat>militaryCombatEfficiency</stat>
        <value>1.1</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>0.5</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_militaryRenaissance_wargames</defName>
    <label>War Games</label>
    <desc>Mock battles rage across the {FACTION_TITLE} as settlements pit their garrisons against one another. The competition is fierce and the training invaluable — but word of your military exercises reaches hostile ears. Rivals take notice of your growing strength.</desc>
    <category>EC_Military</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_militaryRenaissance_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>2</value>
      </li>
      <li>
        <stat>militaryCombatEfficiency</stat>
        <value>1.1</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>0.5</value>
      </li>
      <li>
        <stat>threatScalingMultiplier</stat>
        <value>1.25</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_militaryRenaissance_training</defName>
    <label>Military Academy</label>
    <desc>Your investment funds permanent training grounds, weapons ranges, and drill fields across the {FACTION_TITLE}. The immediate effects are modest as resources are diverted to construction, but the long-term improvement to military readiness is undeniable.</desc>
    <category>EC_Military</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_militaryRenaissance_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>0.5</value>
      </li>
      <li>
        <stat>militaryCombatEfficiency</stat>
        <value>1.05</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>0.25</value>
      </li>
    </statModifiers>
    <permanentStatModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>0.5</value>
      </li>
    </permanentStatModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_militaryRenaissance_civic</defName>
    <label>Civic Works Program</label>
    <desc>The surge of martial energy is channeled into construction, farming, and infrastructure projects. Soldiers trade swords for hammers, and their discipline and teamwork translate surprisingly well to civilian labor. Production rises across the board, and citizens welcome the visible investment in their communities.</desc>
    <category>EC_Economy</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_militaryRenaissance_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>workerProductionMultiplier</stat>
        <value>1.15</value>
      </li>
      <li>
        <stat>happinessGainedBase</stat>
        <value>0.5</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_militaryRenaissance_tournament</defName>
    <label>Grand Tournament</label>
    <desc>Champions from across the {FACTION_TITLE} gather for a spectacular tournament. Crowds roar in delight as they watch Knights joust and soldiers compete in feats of arms. The spectacle hones martial skills while building fierce loyalty — warriors fight harder for a liege who honors their prowess.</desc>
    <category>EC_Military</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_militaryRenaissance_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>1</value>
      </li>
      <li>
        <stat>happinessGainedBase</stat>
        <value>1</value>
      </li>
      <li>
        <stat>loyaltyGainedBase</stat>
        <value>0.5</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

  <FactionColonies.FCEventDef>
    <defName>empireEvents_militaryRenaissance_raids</defName>
    <label>Raiding Campaign</label>
    <desc>The martial enthusiasm is directed outward in a campaign of aggressive raiding. Soldiers eager for glory strike at enemy supply lines, outposts, and caravans. The plunder is impressive and military capabilities surge — but the constant offensive posture breeds a culture of violence that takes its toll back home.</desc>
    <category>EC_Military</category>
    <timeTillTrigger>600000</timeTillTrigger>
    <timeTillTriggerMax>900000</timeTillTriggerMax>
    <targetAllSettlements>true</targetAllSettlements>
    <incompatibleEvents>
      <li>empireEvents_militaryRenaissance_0</li>
    </incompatibleEvents>
    <statModifiers>
      <li>
        <stat>militaryBaseLevel</stat>
        <value>2</value>
      </li>
      <li>
        <stat>militaryCombatEfficiency</stat>
        <value>1.15</value>
      </li>
      <li>
        <stat>unrestGainedBase</stat>
        <value>1</value>
      </li>
    </statModifiers>
  </FactionColonies.FCEventDef>

</Defs>
